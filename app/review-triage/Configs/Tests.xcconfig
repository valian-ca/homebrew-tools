#include "Shared.xcconfig"

PRODUCT_BUNDLE_IDENTIFIER = ca.valian.review-triage.tests
PRODUCT_NAME = ReviewTriageTests

// Let xcodebuild synthesise Info.plist for the test bundle — no need to hand-
// maintain one for a logic-test target.
GENERATE_INFOPLIST_FILE = YES

// Tests always run unsigned / ad-hoc — never with Developer ID, even in Release config.
CODE_SIGN_STYLE = Automatic
CODE_SIGN_IDENTITY = -
CODE_SIGNING_REQUIRED = NO
