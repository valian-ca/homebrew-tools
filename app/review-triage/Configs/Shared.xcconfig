MACOSX_DEPLOYMENT_TARGET = 15.0
SWIFT_VERSION = 6.0
MARKETING_VERSION = 0.3.0
CURRENT_PROJECT_VERSION = 1

// Strict concurrency: surface Sendable issues at compile time on the way to Swift 7.
SWIFT_STRICT_CONCURRENCY = complete
SWIFT_TREAT_WARNINGS_AS_ERRORS = NO

// User-script sandboxing is OFF because the App target's post-build script
// reaches into BUILT_PRODUCTS_DIR to copy the CLI binary into the .app bundle,
// which the sandbox blocks without per-script entitlement gymnastics.
ENABLE_USER_SCRIPT_SANDBOXING = NO
DEAD_CODE_STRIPPING = YES
ENABLE_MODULE_VERIFIER = YES
