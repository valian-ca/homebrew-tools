#!/usr/bin/env bash
# frn — flutter run, with a fast device picker.
#
# Dependencies: gum (charmbracelet), jq. adb + xcrun as needed per platform.
#   brew install gum jq
#
# Usage:
#   frn                       # flavor=development, device menu
#   frn --flavor staging      # override flavor
#   frn -- --dart-define=X=1  # anything after -- is forwarded to flutter run
#
# Env vars:
#   FLUTTER_FLAVOR          default: development
#   FLUTTER_VMSERVICE_FILE  default: .dart_tool/valian/vmservice.uri

set -euo pipefail

# Precedence (low → high): hardcoded defaults < env vars < state file < CLI args.
FLAVOR="development"
VMSERVICE_FILE=".dart_tool/valian/vmservice.uri"
STATE_FILE="${FRN_STATE_FILE:-.dart_tool/valian/frn.json}"
SAVED_DEVICE_ID=""

# Env vars override hardcoded defaults.
[ -n "${FLUTTER_FLAVOR:-}" ]         && FLAVOR="$FLUTTER_FLAVOR"
[ -n "${FLUTTER_VMSERVICE_FILE:-}" ] && VMSERVICE_FILE="$FLUTTER_VMSERVICE_FILE"

# State file overrides env vars (reflects the user's last deliberate choice).
if [ -f "$STATE_FILE" ] && command -v jq >/dev/null 2>&1; then
  _sf=$(jq -r '.flavor // empty'         "$STATE_FILE" 2>/dev/null || true)
  _sv=$(jq -r '.vmservice_file // empty' "$STATE_FILE" 2>/dev/null || true)
  _sd=$(jq -r '.device_id // empty'      "$STATE_FILE" 2>/dev/null || true)
  [ -n "$_sf" ] && FLAVOR="$_sf"
  [ -n "$_sv" ] && VMSERVICE_FILE="$_sv"
  SAVED_DEVICE_ID="$_sd"
  unset _sf _sv _sd
fi

usage() {
  cat <<EOF
frn — flutter run, with a fast device picker.

USAGE
  frn [options] [-- args forwarded to flutter run]

OPTIONS
  --flavor <name>       Flavor to use (default: $FLAVOR).
  --vmservice=<path>    Path for --vmservice-out-file
                        (default: $VMSERVICE_FILE).
  -h, --help            Show this help.

  Anything else is forwarded as-is to \`flutter run\`. Use \`--\`
  to avoid ambiguity:
    frn -- --dart-define=FOO=1 --release

ENVIRONMENT
  FLUTTER_FLAVOR           Override the default flavor.
  FLUTTER_VMSERVICE_FILE   Override the vmservice output file.
  FRN_STATE_FILE           Path to the state file
                           (default: .dart_tool/valian/frn.json).

STATE
  Each successful launch writes flavor, device, and vmservice path to
  the state file. On next run, those values are loaded as defaults; the
  saved device is reused if it's still connected, otherwise the picker
  is shown. Delete the state file to reset.

DEPENDENCIES
  gum, jq, adb, xcrun (depending on which platforms you target).

EXAMPLES
  frn                              # development, device menu
  frn --flavor staging             # override flavor
  frn -d 2B021FDH3005LU            # skip the menu, device already known
  frn -- --dart-define=API_URL=…   # extras forwarded to flutter run
EOF
}

# Minimal option parsing; the rest is forwarded to flutter run.
EXTRA_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)       usage; exit 0 ;;
    --flavor)        FLAVOR="$2"; shift 2 ;;
    --flavor=*)      FLAVOR="${1#*=}"; shift ;;
    --vmservice=*)   VMSERVICE_FILE="${1#*=}"; shift ;;
    --)              shift; EXTRA_ARGS+=("$@"); break ;;
    *)               EXTRA_ARGS+=("$1"); shift ;;
  esac
done

# Best-effort discovery of flavors defined in the current Flutter project.
# Sources (unioned, deduped): android/app/build.gradle(.kts) productFlavors,
# ios/Runner.xcodeproj/xcshareddata/xcschemes/*.xcscheme, lib/main_*.dart.
detect_flavors() {
  {
    if [ -f android/app/build.gradle ]; then
      awk '
        /productFlavors[[:space:]]*\{/ { in_block=1; depth=1; next }
        in_block {
          n = gsub(/\{/, "{"); m = gsub(/\}/, "}")
          depth += n - m
          if (depth <= 0) { in_block=0; exit }
          line = $0; sub(/^[[:space:]]+/, "", line)
          if (match(line, /^[a-zA-Z_][a-zA-Z0-9_]*[[:space:]]*\{/)) {
            name = substr(line, 1, RLENGTH)
            sub(/[[:space:]]*\{.*$/, "", name)
            print name
          }
        }' android/app/build.gradle
    fi
    if [ -f android/app/build.gradle.kts ]; then
      awk '
        /productFlavors[[:space:]]*\{/ { in_block=1; depth=1; next }
        in_block {
          n = gsub(/\{/, "{"); m = gsub(/\}/, "}")
          depth += n - m
          if (depth <= 0) { in_block=0; exit }
          if (match($0, /create\("[^"]+"\)/)) {
            s = substr($0, RSTART, RLENGTH)
            sub(/^create\("/, "", s); sub(/"\)$/, "", s)
            print s
          }
        }' android/app/build.gradle.kts
    fi
    find ios/Runner.xcodeproj/xcshareddata/xcschemes -maxdepth 1 -type f -name '*.xcscheme' 2>/dev/null \
      | sed -E 's|.*/||; s|\.xcscheme$||' \
      | grep -v '^Runner$' \
      | sed -E 's|^Runner-||'
    find lib -maxdepth 1 -type f -name 'main_*.dart' 2>/dev/null \
      | sed -E 's|.*main_([^.]+)\.dart|\1|'
  } 2>/dev/null | awk 'NF && !seen[$0]++'
}

FLAVORS=()
while IFS= read -r line; do
  [ -n "$line" ] && FLAVORS+=("$line")
done < <(detect_flavors)

# Probe platforms in parallel. Each probe writes
# "<label>\t<device_id>" lines to a file, or nothing if unavailable.
TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT

# Run a command with a wall-clock timeout (seconds). Uses macOS-native perl
# so no extra dependency is needed — SIGALRM is preserved across exec, so
# the child gets killed if it runs too long.
with_timeout() {
  perl -e 'alarm shift @ARGV; exec { $ARGV[0] } @ARGV' "$@"
}

# --- Android (USB + wireless) ---
# The adb daemon is notorious for hanging; a timeout keeps frn responsive.
# On timeout we drop a marker so the picker can offer a restart/reconnect.
probe_android() {
  command -v adb >/dev/null 2>&1 || return 0
  if ! with_timeout 5 adb devices -l > "$TMP/android.raw" 2>/dev/null; then
    : > "$TMP/adb_timeout"
    : > "$TMP/android"
    return 0
  fi
  awk '
    NR > 1 && $2 == "device" {
      serial = $1
      model = "Android"
      for (i = 3; i <= NF; i++) {
        if ($i ~ /^model:/) { sub(/^model:/, "", $i); gsub(/_/, " ", $i); model = $i }
      }
      tag = (serial ~ /:/) ? "wifi" : "usb"
      printf " %s (%s)\t%s\n", model, tag, serial
    }' "$TMP/android.raw" > "$TMP/android" 2>/dev/null || true
}

# --- iOS physical (Xcode 15+: devicectl) ---
probe_ios() {
  command -v xcrun >/dev/null 2>&1 || return 0
  xcrun devicectl list devices --json-output "$TMP/ios.json" >/dev/null 2>&1 || return 0
  jq -r '
    .result.devices[]?
    | select(.hardwareProperties.platform == "iOS")
    | select(.connectionProperties.pairingState == "paired")
    | " \(.deviceProperties.name) (\(.connectionProperties.transportType))\t\(.hardwareProperties.udid)"
  ' "$TMP/ios.json" 2>/dev/null > "$TMP/ios" || true
}

# --- Booted iOS simulators ---
probe_sim() {
  command -v xcrun >/dev/null 2>&1 || return 0
  xcrun simctl list devices booted --json 2>/dev/null \
    | jq -r '
        .devices
        | to_entries[]
        | .value[]?
        | select(.state == "Booted")
        | " \(.name) (simulator)\t\(.udid)"
      ' > "$TMP/sim" 2>/dev/null || true
}

probe_all_devices() {
  rm -f "$TMP/android" "$TMP/ios" "$TMP/sim" "$TMP/adb_timeout"
  probe_android & probe_ios & probe_sim &
  wait
  cat "$TMP"/android "$TMP"/ios "$TMP"/sim 2>/dev/null > "$TMP/all" || true
}

# Kill a hung adb daemon and start a fresh one.
restart_adb() {
  command -v adb >/dev/null 2>&1 || return 1
  echo "Restarting adb..." >&2
  pkill -9 adb 2>/dev/null || true
  with_timeout 5 adb start-server >/dev/null 2>&1 || {
    echo "adb start-server timed out." >&2
    return 1
  }
}

# Rediscover and reconnect wireless ADB devices via mDNS. Mirrors the
# adb-reconnect zsh helper: drop stale IP connections, discover tls-connect
# services, reconnect; if no services are advertised, restart adb and retry.
reconnect_wireless_adb() {
  command -v adb >/dev/null 2>&1 || return 1
  local stale
  while IFS= read -r stale; do
    [ -z "$stale" ] && continue
    echo "Disconnecting stale $stale..." >&2
    with_timeout 5 adb disconnect "$stale" >/dev/null 2>&1 || true
  done < <(with_timeout 5 adb devices 2>/dev/null | awk '/^[0-9]+\./ {print $1}' || true)

  local ports=() p
  while IFS= read -r p; do
    [ -n "$p" ] && ports+=("$p")
  done < <(with_timeout 5 adb mdns services 2>/dev/null \
    | awk '/_adb-tls-connect/ {print $NF}' | awk '!seen[$0]++' | tail -r || true)

  if [ ${#ports[@]} -eq 0 ]; then
    echo "No wireless services found, restarting adb..." >&2
    restart_adb || return 1
    sleep 1
    while IFS= read -r p; do
      [ -n "$p" ] && ports+=("$p")
    done < <(with_timeout 5 adb mdns services 2>/dev/null \
      | awk '/_adb-tls-connect/ {print $NF}' | awk '!seen[$0]++' | tail -r || true)
  fi
  if [ ${#ports[@]} -eq 0 ]; then
    echo "No wireless debugging service found. Is it enabled on your phone?" >&2
    return 1
  fi

  local addr
  for addr in ${ports[@]+"${ports[@]}"}; do
    echo "Trying $addr..." >&2
    if with_timeout 5 adb connect "$addr" 2>&1 | grep -q 'connected'; then
      echo "Connected to $addr" >&2
      return 0
    fi
  done
  echo "Failed to connect to any discovered service." >&2
  return 1
}

probe_all_devices

# Pick a device.
#   - Without $1: auto-pick silently if the saved device is still connected,
#     or if there's exactly one device. Otherwise show the picker.
#   - With $1="menu": always show the picker (used from the summary menu so
#     the user can rescan even with a single device).
#   The picker always offers a "↻ Rescan devices" entry at the bottom to
#   re-probe adb/devicectl/simctl without restarting frn.
pick_device() {
  local force_menu="${1:-}"
  local n line picked
  if [ -z "$force_menu" ] && [ -n "$SAVED_DEVICE_ID" ]; then
    line=$(awk -F'\t' -v id="$SAVED_DEVICE_ID" '$2 == id {print; exit}' "$TMP/all")
    SAVED_DEVICE_ID=""  # consume: re-entry from menu uses the picker
    if [ -n "$line" ]; then
      DEVICE_ID=$(printf '%s' "$line" | awk -F'\t' '{print $2}')
      DEVICE_LABEL=$(printf '%s' "$line" | awk -F'\t' '{print $1}')
      return 0
    fi
    # Saved device not connected anymore; fall through to the picker.
  fi
  if [ -z "$force_menu" ]; then
    n=$(wc -l < "$TMP/all" 2>/dev/null || echo 0)
    if [ "$n" -eq 1 ]; then
      line=$(cat "$TMP/all")
      DEVICE_ID=$(printf '%s' "$line" | awk -F'\t' '{print $2}')
      DEVICE_LABEL=$(printf '%s' "$line" | awk -F'\t' '{print $1}')
      return 0
    fi
  fi
  while true; do
    n=$(wc -l < "$TMP/all" 2>/dev/null || echo 0)
    local menu=() entry header="Device"
    if [ "$n" -gt 0 ]; then
      while IFS= read -r entry; do
        [ -n "$entry" ] && menu+=("$entry")
      done < <(awk -F'\t' '{print $1}' "$TMP/all" 2>/dev/null)
    fi
    menu+=("↻ Rescan devices")
    if command -v adb >/dev/null 2>&1; then
      menu+=("↻ Restart adb server")
      # Reconnect is pointless when adb is hung — skip it in that case.
      [ -f "$TMP/adb_timeout" ] || menu+=("↻ Reconnect wireless adb")
    fi
    if [ "$n" -eq 0 ]; then
      header="No devices"
      menu+=("Cancel")
      echo "No devices found. Connect a device or start a simulator/emulator, then rescan." >&2
    fi
    picked=$(printf '%s\n' "${menu[@]}" | gum choose --header="$header" || true)
    [ -n "$picked" ] || return 1
    case "$picked" in
      "↻ Rescan devices")          probe_all_devices; continue ;;
      "↻ Restart adb server")      restart_adb || true; probe_all_devices; continue ;;
      "↻ Reconnect wireless adb")  reconnect_wireless_adb || true; probe_all_devices; continue ;;
      "Cancel")                    return 1 ;;
    esac
    line=$(awk -F'\t' -v l="$picked" '$1 == l {print; exit}' "$TMP/all")
    DEVICE_ID=$(printf '%s' "$line" | awk -F'\t' '{print $2}')
    DEVICE_LABEL=$(printf '%s' "$line" | awk -F'\t' '{print $1}')
    return 0
  done
}

pick_device || { echo "Cancelled." >&2; exit 1; }

# Summary / edit loop. "Launch" is the first row so <enter> confirms.
while true; do
  ACTION=$(printf '%s\n' \
    "▶ Launch" \
    "Flavor     → $FLAVOR" \
    "Device     → $DEVICE_LABEL" \
    "VM out     → $VMSERVICE_FILE" \
    "Cancel" \
    | gum choose --header="frn — enter to launch, or pick a row to edit" || true)

  case "$ACTION" in
    "▶ Launch")  break ;;
    "Cancel"|"") echo "Cancelled." >&2; exit 0 ;;
    "Flavor"*)
      if [ ${#FLAVORS[@]} -gt 0 ]; then
        PICKED=$(printf '%s\n' "${FLAVORS[@]}" "Custom…" \
          | gum choose --selected="$FLAVOR" --header="Flavor" || true)
        case "$PICKED" in
          "")        : ;;  # cancelled, keep current
          "Custom…")
            NEW=$(gum input --value="$FLAVOR" --prompt="Flavor > " || true)
            [ -n "$NEW" ] && FLAVOR="$NEW"
            ;;
          *)         FLAVOR="$PICKED" ;;
        esac
      else
        NEW=$(gum input --value="$FLAVOR" --prompt="Flavor > " || true)
        [ -n "$NEW" ] && FLAVOR="$NEW"
      fi
      ;;
    "Device"*)
      pick_device menu || true
      ;;
    "VM out"*)
      NEW=$(gum input --value="$VMSERVICE_FILE" --prompt="VM service file > " || true)
      [ -n "$NEW" ] && VMSERVICE_FILE="$NEW"
      ;;
  esac
done

mkdir -p "$(dirname "$VMSERVICE_FILE")"

# Persist the selection for next time.
mkdir -p "$(dirname "$STATE_FILE")"
jq -n \
  --arg flavor "$FLAVOR" \
  --arg device_id "$DEVICE_ID" \
  --arg device_label "$DEVICE_LABEL" \
  --arg vmservice_file "$VMSERVICE_FILE" \
  '{flavor: $flavor, device_id: $device_id, device_label: $device_label, vmservice_file: $vmservice_file}' \
  > "$STATE_FILE" 2>/dev/null || true

echo "→ flutter run --flavor $FLAVOR --vmservice-out-file=$VMSERVICE_FILE -d $DEVICE_ID ${EXTRA_ARGS[*]:-}" >&2

exec flutter run \
  --flavor "$FLAVOR" \
  --vmservice-out-file="$VMSERVICE_FILE" \
  -d "$DEVICE_ID" \
  ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}
